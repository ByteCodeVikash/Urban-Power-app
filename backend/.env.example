# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=urbanpower
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API Settings
PROJECT_NAME="Urban Power Backend"
API_V1_STR=/api/v1

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS Origins (Comma-separated or JSON list)
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8081,http://localhost:19006,exp://*"

# MSG91 Configuration
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
SMS_MOCK=true

# JWT Authentication Configuration
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Firebase Configuration
FIREBASE_API_KEY=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Google Sheets Configuration
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEET_ID=

# Google Maps Configuration
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MOCK=true

# Storage Configuration
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
